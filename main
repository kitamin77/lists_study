list_1 = [1, 2, 3, 4, 10]
list_2 = [5, 6, 7, 8]

def summ(list_1, list_2):
    list_3 = []
    max_len = max(len(list_1), len(list_2))
    for i in range(0, max_len):
        if i < len(list_1):
            a = list_1[i]
        else: a = 0
        if i < len(list_2):
            b = list_2[i]
        else: b = 0
        list_3.append(a + b)
    return list_3




summ(list_1, list_2)

print(f'список 1: {list_1}')
print((f'список 2: {list_2}'))
print(f'сумма списков: {summ(list_1, list_2)}')
